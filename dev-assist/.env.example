# dev-assist — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Then: source .env  (or add to your shell profile)
# ─────────────────────────────────────────────────────────────────────────────

# ── AI API Key (for api engine mode) ─────────────────────────────────────────
# export DEV_ASSIST_API_KEY="gsk_your_groq_or_openai_key_here"

# ── SMTP (for email OTP — required for password recovery) ────────────────────
# Gmail example (use App Password, not your real password):
#   1. Enable 2FA on Google account
#   2. Go to myaccount.google.com/apppasswords
#   3. Generate app password for "Mail"
#
# export SMTP_HOST="smtp.gmail.com"
# export SMTP_PORT="587"
# export SMTP_USER="your_gmail@gmail.com"
# export SMTP_PASS="xxxx xxxx xxxx xxxx"   # 16-char app password
# export SMTP_FROM="dev-assist <your_gmail@gmail.com>"

# ── Other SMTP providers ──────────────────────────────────────────────────────
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587
#   SMTP_USER=apikey  SMTP_PASS=SG.your_api_key_here
#
# Outlook/Hotmail:
#   SMTP_HOST=smtp.office365.com  SMTP_PORT=587
#   SMTP_USER=your@outlook.com  SMTP_PASS=your_password
#
# Mailgun:
#   SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
#   SMTP_USER=postmaster@yourdomain.mailgun.org  SMTP_PASS=your_mailgun_key

# ── Data directory (optional — default: ~/.config/dev-assist) ─────────────────
# export DEV_ASSIST_DATA_DIR="/path/to/custom/data/dir"

# ── Config directory (optional) ───────────────────────────────────────────────
# export DEV_ASSIST_CONFIG_DIR="/path/to/custom/config/dir"
